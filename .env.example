# Copy this file to ".env.local" (or set these in your Vercel project settings)
# and fill the values. All NEXT_PUBLIC_* vars are inlined into the client bundle
# at build time, so changing them requires a rebuild/redeploy.

# Google AdSense publisher id (looks like "ca-pub-1234567890123456").
# Leave EMPTY to ship with ads OFF — the site then shows only the reserved
# placeholder boxes. Set it (and redeploy) once your AdSense account is approved.
# Ads only ever load AFTER the visitor accepts cookies.
NEXT_PUBLIC_ADSENSE_CLIENT=
